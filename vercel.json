{
  "crons": [
    { "path": "/api/scan?mode=fetch", "schedule": "0 8 * * *" },
    { "path": "/api/scan?mode=fetch", "schedule": "0 14 * * *" },
    { "path": "/api/scan?mode=fetch", "schedule": "0 20 * * *" },
    { "path": "/api/scan?mode=analyze", "schedule": "15 * * * *" },
    { "path": "/api/tcpa-ingest?source=all&mode=daily", "schedule": "0 */2 * * *" },
    { "path": "/api/agents?run=freshness", "schedule": "0 * * * *" },
    { "path": "/api/agents?run=source-monitor", "schedule": "30 * * * *" },
    { "path": "/api/agents?run=tcpa-backfill", "schedule": "45 * * * *" }
  ],
  "functions": {
    "api/scan.js": {
      "maxDuration": 300
    },
    "api/tcpa-ingest.js": {
      "maxDuration": 300
    },
    "api/agents.js": {
      "maxDuration": 60
    },
    "api/leads.js": {
      "maxDuration": 30
    },
    "api/opportunities.js": {
      "maxDuration": 120
    },
    "api/brief.js": {
      "maxDuration": 30
    },
    "api/judge.js": {
      "maxDuration": 60
    },
    "api/case-summary.js": {
      "maxDuration": 60
    },
    "api/intake-site.js": {
      "maxDuration": 60
    },
    "api/intake.js": {
      "maxDuration": 10
    },
    "api/chat.js": {
      "maxDuration": 120
    },
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/memo.js": {
      "maxDuration": 120
    },
    "api/clients.js": {
      "maxDuration": 30
    },
    "api/match-clients.js": {
      "maxDuration": 120
    },
    "api/intake-screen.js": {
      "maxDuration": 60
    },
    "api/outreach.js": {
      "maxDuration": 60
    },
    "api/briefing.js": {
      "maxDuration": 60
    },
    "api/bulk-outreach.js": {
      "maxDuration": 60
    },
    "api/campaigns.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
