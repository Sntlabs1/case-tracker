{
  "crons": [
    { "path": "/api/scan", "schedule": "*/30 * * * *" }
  ],
  "functions": {
    "api/scan.js": {
      "maxDuration": 300
    },
    "api/leads.js": {
      "maxDuration": 30
    },
    "api/opportunities.js": {
      "maxDuration": 60
    },
    "api/brief.js": {
      "maxDuration": 30
    },
    "api/judge.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
